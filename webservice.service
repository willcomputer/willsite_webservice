[Unit]
Description=Backend for will.computer
After=network.target

[Service]
ExecStart=/usr/bin/python3 -u /home/will/will.computer/backend/wsgi.py
WorkingDirectory=/home/will/WorkingDirectory
StandardOutput=inherit
StandardError=inherit
Restart=always
RestartSec=5
User=nobody
Group=nogroup

[Install]
WantedBy=multi-user.target
