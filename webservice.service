[Unit]
Description=WillSite Flask Web Service
After=network.target

[Service]
User=will
Group=will

WorkingDirectory=/home/will/willsite_webservice/src

ExecStart=/usr/bin/python3 -m gunicorn \
    --workers 1 \
    --bind 127.0.0.1:8000 \
    wsgi:app


Restart=always
RestartSec=5

StandardOutput=append:/home/will/gunicorn.log
StandardError=append:/home/will/gunicorn-error.log

[Install]
WantedBy=multi-user.target